      "seed": 1326716508,
      "version": 264,
      "versionNonce": 1572043535,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1762397978933,
      "link": null,
      "locked": false,
      "text": "Enterprise class open source relational databases.\nsupports SQL (Relational) and JSON(non-relational) querying.\nAdvanced datatypes and support a level of performance optimization",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Enterprise class open source relational databases.\nsupports SQL (Relational) and JSON(non-relational) querying.\nAdvanced datatypes and support a level of performance optimization",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "HVbb5JERkd_ndWhhvBVEp",
      "type": "text",
      "x": -580.2005420945134,
      "y": 2444.832213665941,
      "width": 1186.3795166015625,
      "height": 405,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ab",
      "roundness": null,
      "seed": 1969979612,
      "version": 371,
      "versionNonce": 842736129,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1762397965246,
      "link": null,
      "locked": false,
      "text": "Features\nMulti-version concurrency control(MVCC)\nGranular access controls\nTablespaces\nasynchronous replication \nonline/hot backups write ahead logging \nsupports international character sets\nhighly scalable both in the quantity of data \nPostgreSqls write ahead logging makes it ahighly fault tolerant database",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Features\nMulti-version concurrency control(MVCC)\nGranular access controls\nTablespaces\nasynchronous replication \nonline/hot backups write ahead logging \nsupports international character sets\nhighly scalable both in the quantity of data \nPostgreSqls write ahead logging makes it ahighly fault tolerant database",
      "autoResize": true,
      "lineHeight": 1.25
    },
