      "isDeleted": false,
      "boundElements": null,
      "updated": 1762669486176,
      "link": null,
      "locked": false,
      "text": "Write Ahead log is an append-only series of instrucctions that captures every atomic database change(i.e every transaction).",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Write Ahead log is an append-only series of instrucctions that captures every atomic database change(i.e every transaction).",
      "autoResize": true,
      "lineHeight": 1.25
