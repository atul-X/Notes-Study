    {
      "id": "96T4qxWEnkdMIxCDyahO3",
      "type": "text",
      "x": 5366.415808351913,
      "y": 3300.7099776865944,
      "width": 2014.8111572265625,
      "height": 45,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
