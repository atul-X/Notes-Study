      "isDeleted": false,
      "boundElements": [],
      "updated": 1762480470724,
      "link": null,
      "locked": false,
      "text": "The postgggres server creates the required files in $PGDATA.\nThe default tablespaces.\nTwo tablespaces are automatically created when the database cluster is initialized.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The postgggres server creates the required files in $PGDATA.\nThe default tablespaces.\nTwo tablespaces are automatically created when the database cluster is initialized.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Q2qmN4tSoml2VwzOfPSIX",
      "type": "text",
