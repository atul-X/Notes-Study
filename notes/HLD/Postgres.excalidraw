    {
      "id": "j5QzAQgBM-KxfPZcG0Hal",
      "type": "text",
      "x": -254.49462691594192,
      "y": 8368.35503209507,
      "width": 1341.863525390625,
      "height": 135,
      "angle": 0,
      "strokeColor": "#e8590c",
