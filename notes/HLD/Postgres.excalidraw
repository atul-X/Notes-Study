      "x": -583.2376514695134,
      "y": 2136.052916790941,
      "width": 1123.1995849609375,
      "height": 135,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 4,
