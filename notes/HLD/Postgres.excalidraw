      "updated": 1762480470724,
      "link": null,
      "locked": false,
      "text": "Introduction to postgresql Tablespace",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Introduction to postgresql Tablespace",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "cu40DsX2J6BmoYvFTatS_",
      "type": "text",
      "x": -282.5755420945138,
      "y": 7526.075456202211,
      "width": 1327.931396484375,
      "height": 135,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0f",
      "roundness": null,
      "seed": 795525007,
      "version": 458,
      "versionNonce": 743737148,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1762480470724,
      "link": null,
      "locked": false,
      "text": "Location on disk where PostgresSQL  stores data files containing database object.\nMap a logical name to a physical location on disk.\nDefault  tablespaces  ",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Location on disk where PostgresSQL  stores data files containing database object.\nMap a logical name to a physical location on disk.\nDefault  tablespaces  ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "l2kSsrxURBh4-s_RNSUgo",
      "type": "text",
      "x": 337.2779735304862,
      "y": 7624.219987452211,
      "width": 710.6397094726562,
      "height": 90,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0g",
      "roundness": null,
      "seed": 878821935,
      "version": 356,
      "versionNonce": 1798848444,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1762480470724,
      "link": null,
      "locked": false,
      "text": "pg_default tablespace stores all user data.\npg_global tablespace stores all global data.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "pg_default tablespace stores all user data.\npg_global tablespace stores all global data.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IFINSDjT56pQKNPhuFqiE",
      "type": "text",
      "x": -285.47425861237093,
      "y": 7892.728637005783,
      "width": 1421.6395263671875,
      "height": 135,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0i",
      "roundness": null,
      "seed": 1020262191,
      "version": 466,
      "versionNonce": 1980819516,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1762480470724,
      "link": null,
      "locked": false,
      "text": "Advantages of using tablespaces \nYou can create a new tablespace on a new fs/drive and use it you can place the frequent\naccess indexes or tables on devices that perform fast.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Advantages of using tablespaces \nYou can create a new tablespace on a new fs/drive and use it you can place the frequent\naccess indexes or tables on devices that perform fast.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5RsLP0kgNdCyU8wq45y3A",
      "type": "text",
      "x": -280.5814014695143,
      "y": 7760.069596827211,
      "width": 1267.831909179688,
      "height": 90,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0j",
      "roundness": null,
      "seed": 1815785647,
      "version": 430,
      "versionNonce": 1623228604,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1762480470724,
      "link": null,
      "locked": false,
      "text": "$PG_DATA direcctory location where by default all the data files \nand locations are stored.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "$PG_DATA direcctory location where by default all the data files \nand locations are stored.",
      "autoResize": false,
      "lineHeight": 1.25
    },
