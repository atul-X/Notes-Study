    {
      "id": "ORLOx98npUn1-bCdV2nHM",
      "type": "text",
      "x": -566.6849170945134,
      "y": 2937.9102165956283,
      "width": 351.50390625,
      "height": 45,
      "angle": 0,
      "strokeColor": "#f08c00",
