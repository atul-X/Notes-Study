    {
      "id": "lWajR1VuShOK2XlSlFeTr",
      "type": "text",
      "x": -1936.6117820818417,
      "y": 6379.338603949931,
      "width": 1693.802978515625,
      "height": 105,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5g",
      "roundness": null,
      "seed": 1355466866,
      "version": 3,
      "versionNonce": 1510265842,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1761453220528,
      "link": null,
      "locked": false,
      "text": "If you wish, you can disable persistence altogether. This is the fastest way to run Redis and has no durability guarantees.\n\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If you wish, you can disable persistence altogether. This is the fastest way to run Redis and has no durability guarantees.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "O2ef9KMlnjDWcA53Wm-49",
      "type": "text",
      "x": -2050.4800701641725,
      "y": 6467.061074188026,
      "width": 2321.5103045920937,
      "height": 290.51269531249994,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5k",
      "roundness": null,
      "seed": 1113063662,
      "version": 703,
      "versionNonce": 1344035438,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761456516866,
      "link": null,
      "locked": false,
      "text": "RDB Files\nThe RDB persistence performs point-in-time snapshots of your dataset at specified intervals. The main downside to this mechanism\n is that data between snapshots will be lost. In addition, this storage mechanism also relies on forking the main process, and in a larger \ndataset, this may lead to a momentary delay in serving requests. That being said, RDB files are much faster being loaded in memory than AOF.\n\n\n",
      "fontSize": 33.20145089285718,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "RDB Files\nThe RDB persistence performs point-in-time snapshots of your dataset at specified intervals. The main downside to this mechanism\n is that data between snapshots will be lost. In addition, this storage mechanism also relies on forking the main process, and in a larger \ndataset, this may lead to a momentary delay in serving requests. That being said, RDB files are much faster being loaded in memory than AOF.\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
