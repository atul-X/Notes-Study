    {
      "id": "zc6X_Oj_ELg493qvZQ9uY",
      "type": "image",
      "x": -1480.5494232939727,
      "y": 6992.812504154534,
      "width": 542.9224364421476,
      "height": 339.70355224609375,
      "angle": 0,
