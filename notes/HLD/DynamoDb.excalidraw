      "isDeleted": false,
      "boundElements": null,
      "updated": 1762225145917,
      "link": null,
      "locked": false,
      "text": "In memory caching that provides microsecond response times for read-heavy workloads with automatic\nread/write -through caching ",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In memory caching that provides microsecond response times for read-heavy workloads with automatic\nread/write -through caching ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "C9XlXGr6KSIb78dG1qvPl",
      "type": "text",
      "x": -364.9196317842313,
      "y": 7791.052348582692,
      "width": 1749.8873291015625,
      "height": 135,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
