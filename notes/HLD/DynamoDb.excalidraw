      "type": "text",
      "x": -343.4910603556599,
      "y": 8290.117813147423,
      "width": 1254.5634765625,
      "height": 135,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
