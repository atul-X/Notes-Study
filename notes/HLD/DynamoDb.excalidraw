    {
      "id": "udK0icMM-PqCnj3-DYp6g",
      "type": "text",
      "x": -345.25445321280273,
      "y": 5084.206296685371,
      "width": 901.7998046875,
      "height": 810,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4B",
      "roundness": null,
      "seed": 1624819192,
      "version": 59,
      "versionNonce": 213027320,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1762224548274,
      "link": null,
      "locked": false,
      "text": "1. Simple GET Item Operation\nPartiQL Statement:\n\nSQL\n\nSELECT * FROM Products\nWHERE productId = 'P123'\n\nEquivalent DynamoDB API Parameters (using GetItem):\n\nJavaScript\n\nconst params = {\n  TableName: 'Products',\n  Key: {\n    'productId': 'P123'\n  }\n};",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Simple GET Item Operation\nPartiQL Statement:\n\nSQL\n\nSELECT * FROM Products\nWHERE productId = 'P123'\n\nEquivalent DynamoDB API Parameters (using GetItem):\n\nJavaScript\n\nconst params = {\n  TableName: 'Products',\n  Key: {\n    'productId': 'P123'\n  }\n};",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "KvVCaVqi144SFl4gn2LLD",
      "type": "text",
      "x": 636.0457700014829,
      "y": 5093.71539964296,
      "width": 963.1797485351562,
      "height": 1125,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4C",
      "roundness": null,
      "seed": 1390787720,
      "version": 65,
      "versionNonce": 2098068104,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1762224544885,
      "link": null,
      "locked": false,
      "text": "2. UPDATE Item Operation\nPartiQL Statement:\n\nSQL\n\nUPDATE Employees\nSET status = 'Active' \nWHERE employeeId = 500\nEquivalent DynamoDB API Parameters (using UpdateItem):\n\nJavaScript\n\nconst params = {\n  TableName: 'Employees',\n  Key: {\n    'employeeId': 500\n  },\n  UpdateExpression: 'SET #s = :val',\n  ExpressionAttributeNames: {\n    '#s': 'status'\n  },\n  ExpressionAttributeValues: {\n    ':val': 'Active'\n  }\n};",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. UPDATE Item Operation\nPartiQL Statement:\n\nSQL\n\nUPDATE Employees\nSET status = 'Active' \nWHERE employeeId = 500\nEquivalent DynamoDB API Parameters (using UpdateItem):\n\nJavaScript\n\nconst params = {\n  TableName: 'Employees',\n  Key: {\n    'employeeId': 500\n  },\n  UpdateExpression: 'SET #s = :val',\n  ExpressionAttributeNames: {\n    '#s': 'status'\n  },\n  ExpressionAttributeValues: {\n    ':val': 'Active'\n  }\n};",
      "autoResize": true,
      "lineHeight": 1.25
    },
