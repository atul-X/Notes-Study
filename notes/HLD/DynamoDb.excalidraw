      "versionNonce": 160321016,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1762225344333,
      "link": null,
      "locked": false,
      "text": "DDB Streams\nReal time change tracking of table modifications (inserts,updates,deletes) to trigger downstream processing\nlike Lambda funcation replications or analytic.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DDB Streams\nReal time change tracking of table modifications (inserts,updates,deletes) to trigger downstream processing\nlike Lambda funcation replications or analytic.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
